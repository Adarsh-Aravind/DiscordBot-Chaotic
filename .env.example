# Copy this file to `.env` and fill in what you need:
#   cp .env.example .env
#
# Only DISCORD_TOKEN is truly required. Everything else is optional — leaving a
# value blank falls back to the default baked into utils/config.js, shown in the
# comment above each one.


# =============================================================================
# REQUIRED
# =============================================================================

# Bot token from https://discord.com/developers/applications -> Bot -> Token
DISCORD_TOKEN=your_bot_token_here


# =============================================================================
# RIRI — AI chat (mention the bot at the start of a message to talk to her)
# =============================================================================

# Groq API key. Without this, mentioning the bot does nothing.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# default: llama-3.3-70b-versatile
GROQ_MODEL=

# Messages of context riri remembers per person, per channel. default: 8
AI_MEMORY_TURNS=

# Max tokens per reply — replies are meant to be 1-2 lines. default: 120
AI_MAX_TOKENS=

# Request timeout in milliseconds. default: 20000
AI_TIMEOUT_MS=


# =============================================================================
# SERVER IDS — change these to point the bot at a different server
# =============================================================================

# Role allowed to use mod / chaos commands. default: 1322261748895711353
ALLOWED_ROLE_ID=

# User who always has access, regardless of roles. default: 1135904133145178242
ALLOWED_USER_ID=

# Bot owner — receives forwarded DMs, and can use `.reply <user_id> <message>`
# default: unset (DM forwarding is off until you set this)
OWNER_ID=

# Channel that `.hof` posts into. default: 1488848396298096692
HOF_CHANNEL_ID=

# Passive reaction: this user's messages get reacted to. default: 753892329982787624
REACTION_USER_ID=


# =============================================================================
# BEHAVIOUR
# =============================================================================

# Command prefix. default: .
PREFIX=

# How often `.drag` yanks someone to a new channel, in ms. default: 2500
DRAG_INTERVAL_MS=


# =============================================================================
# YOUTUBE UPLOAD NOTIFICATIONS
# =============================================================================

# Comma-separated channel IDs to watch.
# default: the five channel IDs listed in utils/config.js
YOUTUBE_CHANNEL_IDS=

# Discord channel that upload announcements post to. default: 1162427835059806299
YOUTUBE_ANNOUNCE_CHANNEL_ID=

# How often to poll the RSS feeds, in ms. default: 300000 (5 min)
YOUTUBE_POLL_INTERVAL_MS=
